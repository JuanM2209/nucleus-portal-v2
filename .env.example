# ============================================================
# Nucleus Portal — Environment Variables
# Copy to .env and fill in production values
# ============================================================

# ── Database (via PgBouncer) ──
DATABASE_URL=postgres://nucleus:CHANGE_ME@localhost:6432/nucleus
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ──
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME

# ── Auth (CRITICAL: must be random, min 32 chars) ──
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_EXPIRES_IN=15m

# ── Cockpit Device Credentials ──
COCKPIT_USER=admin
COCKPIT_PASSWORD=CHANGE_ME

# ── Backend ──
PORT=3001
NODE_ENV=production

# ── CORS ──
CORS_ORIGIN=https://portal.yourdomain.com
TUNNEL_BASE_URL=https://api.yourdomain.com

# ── Frontend ──
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com

# ── Exposure Tuning (optional — sane defaults) ──
# EXPOSURE_IDLE_TTL_MS=300000        # 5 min idle before teardown
# MAX_EXPOSURES_PER_DEVICE=4         # Max concurrent ports per device
# MAX_ATTACHMENTS_PER_EXPOSURE=20    # Max tabs/users per port
# MAX_ATTACHMENTS_PER_USER=20        # Max sessions per user
