FROM rust:1.82-slim-bookworm

RUN apt-get update && apt-get install -y \
    cmake make git wget pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Install musl cross toolchain for armv7
RUN wget -q https://musl.cc/armv7l-linux-musleabihf-cross.tgz -O /tmp/musl-cross.tgz \
    && tar -xzf /tmp/musl-cross.tgz -C /opt/ \
    && rm /tmp/musl-cross.tgz

ENV PATH="/opt/armv7l-linux-musleabihf-cross/bin:${PATH}"

WORKDIR /build

# Clone mbusd source
RUN git clone https://github.com/3cky/mbusd.git .

# Cross-compile with static linking for ARM32 musl
RUN mkdir build && cd build && \
    cmake .. \
    -DCMAKE_C_COMPILER=armv7l-linux-musleabihf-gcc \
    -DCMAKE_C_FLAGS="-static" \
    -DCMAKE_EXE_LINKER_FLAGS="-static" \
    -DCMAKE_SYSTEM_NAME=Linux \
    -DCMAKE_SYSTEM_PROCESSOR=arm \
    && make -j$(nproc)
