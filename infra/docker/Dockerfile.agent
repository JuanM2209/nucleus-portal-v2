# Nucleus Agent V2 — ARM cross-compile + chisel client
FROM rust:1.84-slim-bookworm AS builder

RUN apt-get update && apt-get install -y \
    gcc-arm-linux-gnueabihf \
    musl-tools \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Add ARM musl target
RUN rustup target add armv7-unknown-linux-musleabihf

# Configure cross-compilation linker
ENV CARGO_TARGET_ARMV7_UNKNOWN_LINUX_MUSLEABIHF_LINKER=arm-linux-gnueabihf-gcc
ENV CC_armv7_unknown_linux_musleabihf=arm-linux-gnueabihf-gcc

WORKDIR /build

# Copy full agent source and build in one step
COPY agent/ agent/

RUN cd agent && cargo build --release --target armv7-unknown-linux-musleabihf

# ── Cross-compile chisel for ARM32 ──
FROM golang:1.23-bookworm AS chisel-builder
WORKDIR /build
RUN git clone --depth 1 --branch v1.10.1 https://github.com/jpillora/chisel.git .
RUN GOOS=linux GOARCH=arm GOARM=7 CGO_ENABLED=0 \
    go build -ldflags="-s -w" -o /chisel .

# ── Runtime stage: Debian slim for ARM ──
FROM arm32v7/debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    iproute2 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/agent/target/armv7-unknown-linux-musleabihf/release/nucleus-agent /usr/local/bin/nucleus-agent
COPY --from=chisel-builder /chisel /usr/local/bin/chisel

COPY agent/mbusd-arm /usr/local/bin/mbusd
COPY agent/agent.example.toml /etc/nucleus/agent.toml

RUN chmod +x /usr/local/bin/nucleus-agent /usr/local/bin/mbusd /usr/local/bin/chisel

ENTRYPOINT ["nucleus-agent"]
CMD ["--config", "/etc/nucleus/agent.toml"]
